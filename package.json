{
  "name": "claude-code-conductor",
  "version": "0.7.2",
  "description": "Hierarchical multi-agent orchestration for Claude Code -- plans, delegates to parallel workers, reviews with Codex, and traces user flows across code boundaries",
  "type": "module",
  "bin": {
    "conduct": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "setup": "node dist/setup.js",
    "postbuild": "node dist/setup.js --quiet 2>/dev/null || true",
    "postinstall": "node dist/setup.js --quiet 2>/dev/null || true"
  },
  "keywords": [
    "claude",
    "agent",
    "conductor",
    "codex",
    "multi-agent",
    "c3"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "files": [
    "dist",
    "commands",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.113",
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "proper-lockfile": "^4.1.2",
    "simple-git": "^3.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
